    },
    "AKRek.HttpApi.Client.ConsoleTestApp": {
      "path": "test/AKRek.HttpApi.Client.ConsoleTestApp/AKRek.HttpApi.Client.ConsoleTestApp.abppkg",
      "folder": "test"
    },
    "AKRek.DbMigrator": {
      "path": "src/AKRek.DbMigrator/AKRek.DbMigrator.abppkg",
      "folder": "src"
    },
    "AKRek.HttpApi.Host": {
      "path": "src/AKRek.HttpApi.Host/AKRek.HttpApi.Host.abppkg",
      "folder": "src"
    },
    "AKRek.Domain": {
      "path": "src/AKRek.Domain/AKRek.Domain.abppkg",
